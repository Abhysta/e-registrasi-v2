generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

model RegisterPelatihan {
  id              Int      @id @default(autoincrement())
  fullName        String
  firstTitle      String?
  endTitle        String?
  NIP             String
  placeBirth      String
  dateBirth       DateTime
  religion        String
  golongan        String
  jabatan         String
  unitKerja       String
  phone           String
  email           String
  nomorSuratTugas String
  training        Training @relation(fields: [kodePelatihan], references: [kodePelatihan])
  kodePelatihan   String

  @@unique([kodePelatihan, NIP])
  @@map("register_pelatihan")
}

model Training {
  id                Int                 @id @default(autoincrement())
  kodePelatihan     String              @unique
  namaPelatihan     String
  tanggalMulai      DateTime
  tanggalBerakhir   DateTime
  registerPelatihan RegisterPelatihan[]

  @@map("training")
}
